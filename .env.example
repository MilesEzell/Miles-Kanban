# Copy this to .env and fill in real values before deploying.

# A long random string used to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string

# Set to false to disable public registration (admin creates users instead).
ALLOW_REGISTRATION=true

# Admin account seeded on first boot (only used if no user with this name exists).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

# Host port the app is reachable on.
PORT=8080
